root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go uses tabs — enforced by gofmt
[*.go]
indent_style = tab
indent_size = 4

# Config files use 2-space indent
[*.{toml,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
